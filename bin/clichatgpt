#!/usr/bin/env bash
set -euo pipefail

# 禁用 history expansion（避免 ! 被 bash 解释）
set +o histexpand

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." &>/dev/null && pwd)"
LIB_DIR="$PROJECT_DIR/lib"
INFRA_DIR="$PROJECT_DIR/lib/infra"

source "$INFRA_DIR/log.source.sh"
source "$INFRA_DIR/deps.source.sh"
source "$INFRA_DIR/config.source.sh"

source "$LIB_DIR/macos_gui.source.sh"
source "$LIB_DIR/clichatgpt.source.sh"

clichatgpt_config_ensure
clichatgpt_config_load

require_cmds jq cliclick pbcopy pbpaste

clichatgpt_talk "$@"
